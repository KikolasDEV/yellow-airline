// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  passport  String
  password  String
  isVip     Boolean  @default(true) // Todos tus usuarios actuales serán VIP
  createdAt DateTime @default(now())
  bookings  Booking[]
}

model Flight {
  id            Int       @id @default(autoincrement())
  origin        String
  destination   String
  departureTime DateTime
  price         Float
  capacity      Int       @default(180) // Capacidad estándar A320
  bookings      Booking[]
}

model Booking {
  id              Int      @id @default(autoincrement())
  user            User     @relation(fields: [userId], references: [id])
  userId          Int
  flight          Flight   @relation(fields: [flightId], references: [id])
  flightId        Int
  
  // Desglose de pasajeros
  adults          Int      @default(1)
  children        Int      @default(0)
  infants         Int      @default(0)
  basePrice       Float    @default(0)
  finalPrice      Float    @default(0)
  currency        String   @default("eur")
  status          String   @default("PENDING")
  bookingReference String  @unique @default(cuid())
  stripeSessionId String?  @unique
  seatNumber      String?
  gate            String?
  boardingGroup   String?
  createdAt       DateTime @default(now())

  // Evitamos que un usuario reserve el mismo vuelo dos veces
  @@unique([userId, flightId]) 
}
